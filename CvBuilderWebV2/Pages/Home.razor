@page "/"
@using CvBuilderWebV2.Dtos
@inject HttpClient Http
@inject IJSRuntime JS

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-16">
    @* --- TITLE WITH LOGO --- *@
    <div class="d-flex align-center mb-8">
        <img src="images/consulteer-logo.svg" style="width:50px; height:50px;" class="mr-4" alt="Company Logo" />
        <MudText Typo="Typo.h3" Style="color: #0A0A33; font-weight: bold;">CV Builder</MudText>
    </div>

    @* Validation summary shown above submit *@
    @if (showValidationErrors && validationErrors.Any())
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            <ul>
                @foreach (var err in validationErrors)
                {
                    <li>@err</li>
                }
            </ul>
        </MudAlert>
    }

    <MudGrid>
        @* 1. PERSONAL INFO — First Name, Last Name, Title are mandatory *@
        <MudItem xs="12" md="4">
            @* The Label has a red star appended; Error/ErrorText shows validation message below the field *@
            <MudTextField @bind-Value="cvData.FirstName"
                          Label="First Name *"
                          Variant="Variant.Outlined"
                          Error="@(showValidationErrors && string.IsNullOrWhiteSpace(cvData.FirstName))"
                          ErrorText="First Name is required" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="cvData.LastName"
                          Label="Last Name *"
                          Variant="Variant.Outlined"
                          Error="@(showValidationErrors && string.IsNullOrWhiteSpace(cvData.LastName))"
                          ErrorText="Last Name is required" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="cvData.Title"
                          Label="Professional Title *"
                          Variant="Variant.Outlined"
                          Error="@(showValidationErrors && string.IsNullOrWhiteSpace(cvData.Title))"
                          ErrorText="Professional Title is required" />
        </MudItem>

        @* 2. ABOUT ME — mandatory *@
        <MudItem xs="12">
            <MudTextField @bind-Value="cvData.AboutMe"
                          Label="About Me *"
                          Variant="Variant.Outlined"
                          Lines="4"
                          Error="@(showValidationErrors && string.IsNullOrWhiteSpace(cvData.AboutMe))"
                          ErrorText="About Me is required" />
        </MudItem>

        @* 3. PROFILE RATINGS — always 3 fixed squares per skill *@
        <MudItem xs="12">
            @* The Label has a red star appended; Error/ErrorText shows validation message below the field *@
            <MudTextField @bind-Value="cvData.Profile"
                          Label="Profile "
                          Variant="Variant.Outlined"/>
        </MudItem>

        @* 4. SKILLS *@
        <MudItem xs="12">
            <MudTextField @bind-Value="cvData.Skills" Label="Technical Skills (Comma separated)" Variant="Variant.Outlined" />
        </MudItem>

        @* 5. WORK EXPERIENCE *@
        <MudItem xs="12">
            <MudText Typo="Typo.h5" Class="mt-6 mb-2" Style="color: #0A0A33;">Work Experience</MudText>
            @foreach (var exp in cvData.Experiences)
            {
                <MudPaper Class="pa-4 mb-4" Elevation="2" Style="border-top: 4px solid #3CD52E;">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="exp.ExpPosition" Label="Position" Variant="Variant.Filled" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="exp.ExpCompanyName" Label="Company" Variant="Variant.Filled" />
                        </MudItem>

                        <MudItem xs="12" md="3">
                            <MudTextField @bind-Value="exp.ExpStartDate" Label="Start Date (MM/YY)" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField @bind-Value="exp.ExpEndDate" Label="End Date (or 'Present')" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="exp.ExpProjectName" Label="Project Name" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="exp.ExpProjectDescription" Label="Short Project Description" Lines="2" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="exp.ExpTechStack" Label="Tech Stack (e.g. .NET, Azure, SQL)" />
                        </MudItem>

                        @* RESPONSIBILITIES — single textarea.
                           Each line the user presses Enter on becomes a separate bullet.
                           Paste of a paragraph → one bullet (no newlines = one item).
                           The @bind-Value here binds to a per-experience raw string stored
                           in responsibilitiesRaw; we convert to List<string> on submit. *@
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-1">
                                Responsibilities
                                <MudText Typo="Typo.caption" Style="color: grey;">
                                    — press Enter to create separate bullet points
                                </MudText>
                            </MudText>
                            <MudTextField T="string"
                                          Value="@GetResponsibilitiesRaw(exp)"
                                          ValueChanged="@((string v) => SetResponsibilitiesRaw(exp, v))"
                                          Label="Responsibilities"
                                          Variant="Variant.Outlined"
                                          Lines="5"
                                          FullWidth="true"
                                          AutoGrow="true" />
                        </MudItem>

                        <MudItem xs="12" Class="d-flex justify-end">
                            <MudButton Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                                       OnClick="@(() => { cvData.Experiences.Remove(exp); responsibilitiesRaw.Remove(exp); })">
                                Remove Experience
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            }
            <MudButton Variant="Variant.Filled" Color="Color.Dark" OnClick="AddExperience"
                       StartIcon="@Icons.Material.Filled.Add"
                       Style="background-color: #0A0A33; color: white;">
                Add Work Experience
            </MudButton>
        </MudItem>

        @* 6. SOCIALS & TRAINING *@
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h6" Style="color: #0A0A33;">Social Links & Portfolio</MudText>
            @foreach (var social in cvData.Socials)
            {
                <MudPaper Class="pa-2 mb-2 d-flex align-center gap-2" Outlined="true">
                    <MudTextField @bind-Value="social.Platform" Label="Platform" />
                    <MudTextField @bind-Value="social.Url" Label="URL" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => cvData.Socials.Remove(social))" />
                </MudPaper>
            }
            <MudButton OnClick="AddSocial" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Secondary">Add Social</MudButton>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h6" Style="color: #0A0A33;">Trainings & Certifications</MudText>
            @foreach (var train in cvData.Trainings)
            {
                <MudPaper Class="pa-2 mb-2 d-flex align-center gap-2" Outlined="true">
                    <MudTextField @bind-Value="train.TrainingName" Label="Certification" />
                    <MudTextField @bind-Value="train.TrainingDate" Label="Date" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => cvData.Trainings.Remove(train))" />
                </MudPaper>
            }
            <MudButton OnClick="AddTraining" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Secondary">Add Training</MudButton>
        </MudItem>

        @* 7, 8, 9. EDUCATION, SOFTWARE STACK, LANGUAGES *@
        <MudItem xs="12">
            <MudText Typo="Typo.h5" Class="mt-4 mb-2" Style="color: #0A0A33;">Education / Degree</MudText>
            @foreach (var edu in cvData.Educations)
            {
                <MudPaper Class="pa-3 mb-2 d-flex align-center gap-4" Outlined="true">
                    <MudTextField @bind-Value="edu.EducationName" Label="Degree & School" Style="flex:4" />
                    <MudTextField @bind-Value="edu.EduEndDate" Label="MM/YY" Style="flex:1" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => cvData.Educations.Remove(edu))" />
                </MudPaper>
            }
            <MudButton OnClick="AddEducation" StartIcon="@Icons.Material.Filled.Add" Color="Color.Secondary" Variant="Variant.Outlined">Add Education</MudButton>
        </MudItem>

        <MudItem xs="12">
            <MudTextField @bind-Value="cvData.ToolStack" Label="Software Stack (Comma separated)" Variant="Variant.Outlined" />
        </MudItem>

        <MudItem xs="12">
            <MudTextField @bind-Value="cvData.Languages" Label="Languages (Comma separated)" Variant="Variant.Outlined" />
        </MudItem>

        @* --- GENERATE BUTTON --- *@
        <MudItem xs="12" Class="d-flex justify-center mt-10">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       OnClick="GenerateCV"
                       Style="width: 350px; height: 60px; background-color: #0A0A33; color: white;">
                GENERATE WORD CV
            </MudButton>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private CVFieldValuesDto cvData = new()
    {
        Experiences = new List<ExperienceDto> { new ExperienceDto { ExpResponsibilities = new List<string> { "" } } },
        Trainings = new(),
        Socials = new(),
        Educations = new()
    };

    // ── Validation ───────────────────────────────────────────────────────────
    private bool showValidationErrors = false;
    private List<string> validationErrors = new();

    private bool Validate()
    {
        validationErrors.Clear();

        if (string.IsNullOrWhiteSpace(cvData.FirstName))   validationErrors.Add("First Name is required.");
        if (string.IsNullOrWhiteSpace(cvData.LastName))    validationErrors.Add("Last Name is required.");
        if (string.IsNullOrWhiteSpace(cvData.Title))       validationErrors.Add("Professional Title is required.");
        if (string.IsNullOrWhiteSpace(cvData.AboutMe))     validationErrors.Add("About Me is required.");

        return validationErrors.Count == 0;
    }

    private Dictionary<ExperienceDto, string> responsibilitiesRaw = new();

    private string GetResponsibilitiesRaw(ExperienceDto exp)
    {
        if (responsibilitiesRaw.TryGetValue(exp, out var raw))
            return raw;

        var initial = string.Join("\n", exp.ExpResponsibilities);
        responsibilitiesRaw[exp] = initial;
        return initial;
    }

    private void SetResponsibilitiesRaw(ExperienceDto exp, string value)
    {
        // Store the raw text.
        responsibilitiesRaw[exp] = value ?? "";

        exp.ExpResponsibilities = (value ?? "")
            .Split('\n')
            .Select(line => line.TrimEnd('\r').Trim())
            .Where(line => !string.IsNullOrEmpty(line))
            .ToList();

        if (exp.ExpResponsibilities.Count == 0)
            exp.ExpResponsibilities.Add("");
    }

    // ── Submit ───────────────────────────────────────────────────────────────
    private async Task GenerateCV()
    {
        showValidationErrors = true;

        if (!Validate())
            return; // red asterisks & error messages are now visible

        var response = await Http.PostAsJsonAsync("cvBuilder/generate", cvData);

        if (response.IsSuccessStatusCode)
        {
            var fileStream = await response.Content.ReadAsStreamAsync();
            using var streamRef = new DotNetStreamReference(stream: fileStream);
            await JS.InvokeVoidAsync("downloadFileFromStream", $"CV_{cvData.FirstName} {cvData.LastName}.docx", streamRef);
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Something went wrong on the server. Check the data and try again.");
        }
    }

    // ── Add helpers ──────────────────────────────────────────────────────────
    private void AddExperience()
    {
        var exp = new ExperienceDto { ExpResponsibilities = new() { "" } };
        cvData.Experiences.Add(exp);
        responsibilitiesRaw[exp] = "";
    }

    private void AddEducation() => cvData.Educations.Add(new EducationDto());
    private void AddTraining() => cvData.Trainings.Add(new TrainingDto());
    private void AddSocial() => cvData.Socials.Add(new SocialDto());
}
